# ─────────────────────────────────────────────────────────────────────────────
# AquaFlow — Production Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
#
# USAGE:
#   1. Copy this file:
#        cp .env.example .env.prod
#
#   2. Fill in every value marked  ← REQUIRED
#
#   3. Generate the Mosquitto password file:
#        docker run --rm eclipse-mosquitto:2 \
#          sh -c "mosquitto_passwd -b /dev/stdout YOUR_MQTT_USERNAME YOUR_MQTT_PASSWORD" \
#          > mosquitto/config/passwd
#
#   4. Add to .gitignore (never commit secrets):
#        .env.prod
#        mosquitto/config/passwd
#
#   5. Start the stack:
#        docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=aquaflow
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_here         # ← REQUIRED
POSTGRES_DB=aquaflow

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here                # ← REQUIRED
# Generate: openssl rand -hex 24

# ── MQTT Broker (Mosquitto) ───────────────────────────────────────────────────
MQTT_USERNAME=aquaflow
MQTT_PASSWORD=CHANGE_ME_mqtt_password_here                  # ← REQUIRED
# After setting these, run step 3 above to create mosquitto/config/passwd

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# MUST be at least 32 random characters each — never reuse between environments
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32      # ← REQUIRED
JWT_REFRESH_SECRET=CHANGE_ME_another_openssl_rand_hex_32    # ← REQUIRED

# ── Public URLs ───────────────────────────────────────────────────────────────
# Set to your actual domain (with https:// for production)
FRONTEND_URL=https://yourdomain.com                         # ← REQUIRED (CORS)
REACT_APP_API_URL=https://yourdomain.com/api                # ← REQUIRED (baked into React bundle)
REACT_APP_WS_URL=https://yourdomain.com                     # ← REQUIRED (WebSocket URL)

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Comma-separated broker list — use service name inside Docker network
KAFKA_BROKERS=kafka:9092

# ── MinIO (S3-compatible data lake) ───────────────────────────────────────────
# Generate strong credentials — never commit these
MINIO_ROOT_USER=CHANGE_ME_minio_user                    # ← REQUIRED
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password_min8chars  # ← REQUIRED (min 8 chars)

# ── SMTP Email (optional) ─────────────────────────────────────────────────────
# Leave SMTP_HOST empty to disable email notifications entirely
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aquaflow.io

# ── Docker Image Tag (optional) ───────────────────────────────────────────────
# Used to pin a specific image version instead of 'latest'
# Example: IMAGE_TAG=v1.2.3
IMAGE_TAG=latest
